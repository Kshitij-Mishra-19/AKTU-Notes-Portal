<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> AKTU Colleges Notes Portal</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head>

<body>

    <!-- Navbar -->
    <%- include("partials/navbar") %>

    <!-- Hero -->
    <div class="hero">
        <h1>📚 AKTU Colleges Notes Portal</h1>
        <p>All your study material in one place.</p>
    </div>

    <!-- Year Cards -->
    <div class="container mb-5">

        <div class="row g-4">

            <% for(let i = 1; i <= 4; i++) { %>

                <div class="col-lg-3 col-md-6">

                    <div class="card year-card shadow h-100">

                        <div class="card-body text-center">

                            <i class="bi bi-journal-bookmark-fill"></i>

                            <h3 class="mt-3">Year <%= i %></h3>

                            <p class="text-muted">
                                Click below to view subjects.
                            </p>

                            <a href="/year/<%= i %>" class="btn btn-primary w-100">
                                Open Year <%= i %>
                            </a>

                        </div>

                    </div>

                </div>

            <% } %>

        </div>

    </div>

    <!-- Footer -->
    <footer>
        © 2026 College Notes Portal | Built by Geetansh Shukla & Kshitij Mishra
    </footer>

</body>
</html>