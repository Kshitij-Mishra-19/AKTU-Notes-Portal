<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Year <%= year %> - College Notes</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

</head>

<body>

<%- include("partials/navbar") %>

<div class="container py-5">

    <div class="text-center mb-5">

        <h1 class="page-title">
            📚 Year <%= year %>
        </h1>

        <p class="text-muted">
            Total Subjects : <strong><%= subjects.length %></strong>
        </p>

    </div>

    <div class="row g-4">

        <% subjects.forEach(function(subject){ %>

        <div class="col-lg-4 col-md-6">

            <div class="card subject-card shadow h-100">

                <div class="card-body text-center">

                    <i class="bi bi-book-half subject-icon"></i>

                    <h4 class="mt-3">
                        <%= subject.name %>
                    </h4>

                    <p class="text-muted">
                        <%= subject.units.length %> Units Available
                    </p>

                    <a href="/year/<%= year %>/subject/<%= subject.id %>"
                       class="btn btn-primary btn-view w-100">

                        <i class="bi bi-folder2-open"></i>
                        View Subject

                    </a>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

</div>

<%- include("partials/footer") %>

</body>
</html>